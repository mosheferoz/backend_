# ============================================================================
# ControlClick billing backend — environment
# Copy to .env and fill real values. NEVER commit a real .env.
# Production secrets belong in the host's secret manager (Railway/Render/etc.).
# ============================================================================

# ---- runtime ----
NODE_ENV=production
PORT=8787

# Public URL of THIS backend — used to build Grow notifyUrl. MUST be the real prod domain.
BACKEND_BASE_URL=https://billing.controlclick.co.il

# Frontend app origin — used for success/cancel redirect URLs. MUST be the real prod domain.
APP_BASE_URL=https://app.controlclick.co.il

# Comma-separated CORS allowlist (defaults to APP_BASE_URL if omitted).
ALLOWED_ORIGINS=https://app.controlclick.co.il

# ---- Supabase ----
SUPABASE_URL=https://ucggbjxevmpcysitveqx.supabase.co
# service_role key (or a dedicated billing_writer role connection) — SECRET.
SUPABASE_SERVICE_ROLE_KEY=replace-me
# JWKS endpoint is derived from SUPABASE_URL by default; override only if needed.
# SUPABASE_JWKS_URL=

# ---- Grow / Meshulam (LIVE) ----
MESHULAM_BASE=https://secure.meshulam.co.il/api/light/server/1.0
# Live account identifiers (from Grow).
MESHULAM_USER_ID=38fb94b23e4a75b7
MESHULAM_PAGE_CODE=2eae4dd04a70
# מחק את השורה הזו — apiKey נדרש רק לחשבונות ריבוי-עסקים, לא לנו.
# MESHULAM_API_KEY=

# ---- gate secrets (rotate; never reuse the old leaked values) ----
# GROW_NOTIFY_SECRET — השתמש ב-secret של חשבון ה-LIVE (לא של ה-sandbox).
GROW_NOTIFY_SECRET=replace-me-LIVE-notify-secret
CRON_SECRET=replace-me-cron-secret

# 32-byte key (base64) for encrypting card tokens at rest.
# Generate with:  openssl rand -base64 32
TOKEN_ENC_KEY=replace-me-base64-32-bytes
