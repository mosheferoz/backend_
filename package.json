  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/node-cron": "^3.0.11",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
