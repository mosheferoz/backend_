# ============================================================================
# ControlClick billing backend — environment
# Copy to .env and fill real values. NEVER commit a real .env.
# Production secrets belong in the host's secret manager (Railway/Render/etc.).
# ============================================================================

# ---- runtime ----
NODE_ENV=development
PORT=8080

# Public URL of THIS backend — used to build Grow notifyUrl.
# e.g. https://billing.controlclick.co.il
BACKEND_BASE_URL=http://localhost:8080

# Frontend app origin — used for success/cancel redirect URLs.
# e.g. https://app.controlclick.co.il
APP_BASE_URL=http://localhost:5173

# Comma-separated CORS allowlist (defaults to APP_BASE_URL if omitted).
ALLOWED_ORIGINS=http://localhost:5173

# ---- Supabase ----
SUPABASE_URL=https://ucggbjxevmpcysitveqx.supabase.co
# service_role key (or a dedicated billing_writer role connection) — SECRET.
SUPABASE_SERVICE_ROLE_KEY=replace-me
# JWKS endpoint is derived from SUPABASE_URL by default; override only if needed.
# SUPABASE_JWKS_URL=

# ---- Grow / Meshulam ----
# sandbox:    https://sandbox.meshulam.co.il/api/light/server/1.0
# production: https://secure.meshulam.co.il/api/light/server/1.0
MESHULAM_BASE=https://sandbox.meshulam.co.il/api/light/server/1.0
# Token-enabled account identifiers (provided by Grow — confirm sandbox vs prod base).
MESHULAM_USER_ID=
MESHULAM_PAGE_CODE=
# Only required for multi-business / certain production endpoints.
MESHULAM_API_KEY=

# ---- gate secrets (rotate; never reuse the old leaked values) ----
GROW_NOTIFY_SECRET=replace-me-notify-secret
CRON_SECRET=replace-me-cron-secret

# 32-byte key (base64) for encrypting card tokens at rest.
# Generate with:  openssl rand -base64 32
TOKEN_ENC_KEY=replace-me-base64-32-bytes
